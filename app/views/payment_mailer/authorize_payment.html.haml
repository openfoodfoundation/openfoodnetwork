= render partial: 'shared/mailers/greeting_and_intro',
         locals: { greeting: t("mailers_shared.customer_greeting", name: @payment.order.bill_address.firstname),
                   intro: t(".intro_html", distributor: @payment.order.distributor.name, amount: @payment.display_amount),
                   enterprise_for_logo: @payment.order.distributor }

%p
  = t(".instructions")
  = link_to main_app.authorize_payment_url(@payment), main_app.authorize_payment_url(@payment)
