- intro_key = @delivery ? ".shipped_intro_html" : ".picked_up_intro_html"

= render partial: 'shared/mailers/greeting_and_intro',
         locals: { greeting: t("mailers_shared.customer_greeting", name: @shipment.order.bill_address.firstname),
                   intro: t(intro_key, distributor: @shipment.order.distributor.name),
                   enterprise_for_logo: @shipment.order.distributor }

%p
  %strong
    = t('.shipment_summary')

%p{ style: "font-family: monospace, serif;" }
  - @shipment.manifest.each do |item|
    = item.variant.sku
    = item.variant.product.name
    = item.variant.options_text
    %br

- if @shipment.tracking.present?
  %p.lead
    = t('.track_information', tracking: @shipment.tracking)

- if @shipment.tracking_url
  %p.lead
    = t('.track_link', url: @shipment.tracking_url)

%p.lead
  = t('.thanks')
