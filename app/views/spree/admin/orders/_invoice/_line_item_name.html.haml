%h5.inline-header
  = line_item.variant.product.name
  - unless line_item.variant.product.name.include? line_item.name_to_display
    %span= "- #{line_item.name_to_display}"
- if line_item.unit_price_amount
  = raw("(#{format_unit_price_with_unit(line_item.unit_price_amount, line_item.unit_price_presentation)})")

