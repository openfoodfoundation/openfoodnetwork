= turbo_frame_tag "shop-products" do
  .loading{ style: "display: none;", "data-product-grid-view-target": "loading" }
    = render partial: "shop/products/product_spinner"

  .products-container{ "data-product-grid-view-target": "products" }
    - @products.each do |product|
      .product-item
        .product-content
          %a{ href:"#", "data-controller": "modal-link", "data-action": "click->modal-link#open", "data-modal-link-target-value": "product-modal-#{product.id}" }
            %p
              - if product.image
                = image_tag(product.image.url(:small), alt: product.image.alt, title: product.image.alt)
              - else
                = image_tag(Spree::Image.default_image_url(:small), class: "placeholder")
              = product.name

          - # Use length here instead of count to only have on query instead of one for count and one query to load variants on the line below
          - if product.variants.length == 1
            - variant = product.variants.first
            .variant
              = render AddToCartComponent.new(variant: variant, quantity: @variants_in_cart[variant.id], low_stock_display: @low_stock_display)

          = render ModalComponent.new(id: "product-modal-#{product.id}", modal_class: "big") do
            = render partial: "shared/product/product_details", locals: { product: }
