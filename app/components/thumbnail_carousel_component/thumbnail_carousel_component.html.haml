%div{ **root_attributes }
  .swiper-wrapper
    - images.each do |image|
      .swiper-slide
        = image_tag image[:url], alt: image[:alt], class: "ofn-thumbnail-carousel__image"
        - if show_captions? && image[:caption].present?
          %p.ofn-thumbnail-carousel__caption= image[:caption]

  - if show_navigation?
    %button.ofn-thumbnail-carousel__button.ofn-thumbnail-carousel__button--prev{
      type: "button",
      **target_attribute("prevButton"),
      "aria-label": "Previous slide"
    }
      %i.fa.fa-chevron-left{ "aria-hidden": "true" }

    %button.ofn-thumbnail-carousel__button.ofn-thumbnail-carousel__button--next{
      type: "button",
      **target_attribute("nextButton"),
      "aria-label": "Next slide"
    }
      %i.fa.fa-chevron-right{ "aria-hidden": "true" }

  - if show_pagination?
    .ofn-thumbnail-carousel__pagination{ **target_attribute("pagination") }

  - if multiple_images?
    .ofn-thumbnail-carousel__thumbs
      - images.each_with_index do |image, index|
        %button.ofn-thumbnail-carousel__thumb{
          type: "button",
          **target_attribute("thumbnail"),
          "data-action": "thumbnail-carousel#goTo",
          "data-slide-index": index,
          "aria-label": "Go to slide #{index + 1}",
          "aria-pressed": "false"
        }
          = image_tag image[:url], alt: image[:alt], class: "ofn-thumbnail-carousel__thumb-image"
