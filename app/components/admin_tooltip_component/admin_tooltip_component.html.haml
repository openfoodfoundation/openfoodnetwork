%div{"data-controller": "tooltip", "data-tooltip-placement-value": @placement }
  - if @no_link_element
    %span{"data-tooltip-target": "element", href: @link, class: @link_class}
      = @link_text 
  - else
    %a{"data-tooltip-target": "element", href: @link, class: @link_class}
      = @link_text 

  .tooltip-container
    .tooltip.radius{"data-tooltip-target": "tooltip"}
      = sanitize @text
      .arrow{"data-tooltip-target": "arrow"}

